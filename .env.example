# =============================================================================
# Lumina Finance — Environment Variables (example)
# Copy this file to `.env.local` and fill in the values. Never commit real secrets.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# -- Application ---------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Lumina Finance"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_ENV="development" # development | staging | production

# -- API / Backend (future) ----------------------------------------------------
# Base URL of the REST/GraphQL API that will power the dashboard.
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
API_SECRET_KEY="replace-with-server-side-secret"

# -- Authentication (future) ----------------------------------------------------
# Reserved for the auth provider (NextAuth/Auth.js, Clerk, custom JWT, etc.).
AUTH_SECRET="generate-a-long-random-string"
AUTH_URL="http://localhost:3000"

# -- Database (future) ----------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/lumina_finance"

# -- Payments / Billing (future) ------------------------------------------------
# Reserved for the payment processor (Stripe, etc.).
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# -- Observability (future) -----------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_ANALYTICS_ID=""

# -- Feature flags --------------------------------------------------------------
NEXT_PUBLIC_ENABLE_3D="true"
NEXT_PUBLIC_ENABLE_NOTIFICATIONS="true"
