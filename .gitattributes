# Normalize line endings to LF on checkin, auto on checkout.
* text=auto eol=lf

# Explicitly declare text files
*.ts      text eol=lf
*.tsx     text eol=lf
*.js      text eol=lf
*.mjs     text eol=lf
*.cjs     text eol=lf
*.json    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.md      text eol=lf
*.mdx     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.html    text eol=lf
*.svg     text eol=lf

# Shell scripts must keep LF endings
*.sh      text eol=lf
.husky/*  text eol=lf

# Windows scripts keep CRLF
*.bat     text eol=crlf
*.cmd     text eol=crlf

# Declare binary files (no diff, no eol conversion)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.avif    binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary
*.pdf     binary
*.glb     binary
*.gltf    binary
*.hdr     binary

# Lockfiles: collapse in diffs and treat as generated
package-lock.json  linguist-generated=true -diff
pnpm-lock.yaml     linguist-generated=true -diff
yarn.lock          linguist-generated=true -diff
